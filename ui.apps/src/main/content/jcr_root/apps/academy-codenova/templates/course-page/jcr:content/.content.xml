<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:PageContent"
    sling:resourceType="academy-codenova/components/structure/course-page"
    cq:template="/apps/academy-codenova/templates/course-page">

    <par
        jcr:primaryType="nt:unstructured"
        sling:resourceType="wcm/foundation/components/parsys">
        <intro_text
            jcr:primaryType="nt:unstructured"
            sling:resourceType="foundation/components/text"
            textIsRich="true"
            text="&lt;p&gt;Add your course description and details here.&lt;/p&gt;"/>
    </par>

    <related-courses
        jcr:primaryType="nt:unstructured"
        sling:resourceType="academy-codenova/components/content/news"
        coursesRoot="/content/codehills/courses"
        sortBy="startDate"/>

</jcr:root>
