<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured">
        <items jcr:primaryType="nt:unstructured">
            <tabs jcr:primaryType="nt:unstructured">
                <items jcr:primaryType="nt:unstructured">

                    <!-- Course Info tab — inserted after Basic, before Images -->
                    <courseinfo
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Course Info"
                        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                        sling:orderBefore="thumbnail">
                        <items jcr:primaryType="nt:unstructured">
                            <column
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <startDate
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/datepicker"
                                        cq:showOnCreate="{Boolean}true"
                                        fieldLabel="Start Date"
                                        fieldDescription="Date the course begins."
                                        name="./startDate"
                                        displayedFormat="DD MMMM YYYY"
                                        valueFormat="YYYY-MM-DD[T00:00:00.000Z]"/>
                                    <startDateTypeHint
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/hidden"
                                        cq:showOnCreate="{Boolean}true"
                                        name="./startDate@TypeHint"
                                        value="Date"/>

                                    <abstract
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                        cq:showOnCreate="{Boolean}true"
                                        fieldLabel="Abstract"
                                        fieldDescription="Short description shown below the title."
                                        name="./abstract"
                                        rows="{Long}4"/>
                                    <link
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                        cq:showOnCreate="{Boolean}true"
                                        fieldLabel="Course Link"
                                        fieldDescription="Optional — defaults to this page if left empty."
                                        name="./link"
                                        rootPath="/content"/>
                                    <tags
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/tagfield"
                                        cq:showOnCreate="{Boolean}true"
                                        fieldLabel="Course Tags"
                                        fieldDescription="Tags used for filtering in the related-courses slider."
                                        name="./cq:tags"
                                        multiple="{Boolean}true"
                                        rootPath="/content/cq:tags"/>
                                    <sep1
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/separator"/>
                                    <fileReference
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                        cq:showOnCreate="{Boolean}true"
                                        fieldLabel="Course Image"
                                        fieldDescription="DAM path to the hero image shown at the top of the course page."
                                        name="./fileReference"
                                        rootPath="/content/dam"/>

                                </items>
                            </column>
                        </items>
                    </courseinfo>

                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
