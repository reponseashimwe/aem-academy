<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Course Page"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                size="L">
                <items jcr:primaryType="nt:unstructured">
                    <basic
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                        <items jcr:primaryType="nt:unstructured">
                            <column
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <!-- Hide Branding and HTML ID -->
                                    <branding
                                        jcr:primaryType="nt:unstructured"
                                        sling:hideResource="{Boolean}true"/>
                                    <htmlid
                                        jcr:primaryType="nt:unstructured"
                                        sling:hideResource="{Boolean}true"/>
                                    
                                    <coursefields
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Course Info"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/fieldset"
                                        sling:orderBefore="moretitles">
                                        <items jcr:primaryType="nt:unstructured">
                                            <startDate
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/datepicker"
                                                cq:showOnCreate="{Boolean}true"
                                                fieldLabel="Start Date"
                                                fieldDescription="Date the course begins."
                                                name="./startDate"
                                                displayedFormat="DD MMMM YYYY"
                                                valueFormat="YYYY-MM-DD[T00:00:00.000Z]"
                                                type="date"/>
                                            <link
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                cq:showOnCreate="{Boolean}true"
                                                fieldLabel="Course Link"
                                                fieldDescription="Optional — defaults to this page if left empty."
                                                name="./link"
                                                rootPath="/content"/>
                                            <tags
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/tagfield"
                                                cq:showOnCreate="{Boolean}true"
                                                fieldLabel="Course Tags"
                                                fieldDescription="Tags used for filtering in the related-courses slider."
                                                name="./cq:tags"
                                                multiple="{Boolean}true"
                                                rootPath="/content/cq:tags"/>
                                        </items>
                                    </coursefields>
                                </items>
                            </column>
                        </items>
                    </basic>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
