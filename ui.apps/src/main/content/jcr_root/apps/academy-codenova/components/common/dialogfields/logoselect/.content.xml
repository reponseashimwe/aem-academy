<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
    jcr:primaryType="nt:unstructured"
    sling:resourceType="granite/ui/components/coral/foundation/container">
    <items jcr:primaryType="nt:unstructured">
        <logoMode
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/form/select"
            granite:class="cq-dialog-dropdown-showhide cl-logo-mode-toggle"
            fieldLabel="Logo Type"
            name="./logoMode">
            <granite:data
                jcr:primaryType="nt:unstructured"
                cq-dialog-dropdown-showhide-target=".cl-logo-mode-target"/>
            <items jcr:primaryType="nt:unstructured">
                <default
                    jcr:primaryType="nt:unstructured"
                    text="Default logo"
                    selected="{Boolean}true"
                    value="default"/>
                <custom
                    jcr:primaryType="nt:unstructured"
                    text="Custom image"
                    value="custom"/>
            </items>
        </logoMode>
        <defaultIconFields
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/container"
            granite:class="hide cl-logo-default-icon-fields cl-logo-mode-target">
            <granite:data
                jcr:primaryType="nt:unstructured"
                showhidetargetvalue="default"/>
            <items jcr:primaryType="nt:unstructured">
                <logoIcon
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/include"
                    path="/apps/academy-codenova/components/common/dialogfields/logoiconselect"/>
            </items>
        </defaultIconFields>
        <assetFields
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/container"
            granite:class="hide cl-logo-asset-fields cl-logo-mode-target">
            <granite:data
                jcr:primaryType="nt:unstructured"
                showhidetargetvalue="custom"/>
            <items jcr:primaryType="nt:unstructured">
                <logoAssetReference
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                    fieldLabel="Logo Asset"
                    fieldDescription="Path to DAM image used as logo when default icon is disabled."
                    name="./logoAssetReference"
                    rootPath="/content/dam"/>
                <logoAltText
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                    fieldLabel="Logo Alt Text"
                    name="./logoAltText"/>
            </items>
        </assetFields>
    </items>
</jcr:root>
