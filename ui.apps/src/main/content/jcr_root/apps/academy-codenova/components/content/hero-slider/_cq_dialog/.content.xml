<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          jcr:primaryType="nt:unstructured"
          jcr:title="Hero Slider"
          sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/tabs">
        <items jcr:primaryType="nt:unstructured">
            <slidesTab
                jcr:primaryType="nt:unstructured"
                jcr:title="Slides"
                sling:resourceType="granite/ui/components/coral/foundation/container">
                <items jcr:primaryType="nt:unstructured">
                    <slides
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                        composite="{Boolean}true"
                        fieldLabel="Slides"
                        fieldDescription="Add 1–10 hero slides. Each slide has image, pretitle, title, subtitle and optional CTA.">
                        <field
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/container"
                            name="./slides">
                            <items jcr:primaryType="nt:unstructured">
                                <image
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                    fieldLabel="Background image"
                                    name="./image"
                                    rootPath="/content/dam"
                                    required="{Boolean}true"/>
                                <pretitle
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldLabel="Pretitle"
                                    name="./pretitle"/>
                                <title
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldLabel="Title"
                                    name="./title"
                                    required="{Boolean}true"/>
                                <subtitle
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                    fieldLabel="Subtitle"
                                    name="./subtitle"
                                    rows="3"/>
                                <ctaLabel
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldLabel="CTA label"
                                    name="./ctaLabel"/>
                                <ctaLink
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                    fieldLabel="CTA link"
                                    name="./ctaLink"
                                    rootPath="/content"/>
                                <ctaVariant
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                    fieldLabel="CTA style"
                                    name="./ctaVariant">
                                    <items jcr:primaryType="nt:unstructured">
                                        <primary
                                            jcr:primaryType="nt:unstructured"
                                            text="Primary"
                                            value="primary"/>
                                        <outline
                                            jcr:primaryType="nt:unstructured"
                                            text="Outline"
                                            value="outline"/>
                                        <ghost
                                            jcr:primaryType="nt:unstructured"
                                            text="Text link"
                                            value="ghost"/>
                                    </items>
                                </ctaVariant>
                            </items>
                        </field>
                    </slides>
                </items>
            </slidesTab>

            <settingsTab
                jcr:primaryType="nt:unstructured"
                jcr:title="Settings"
                sling:resourceType="granite/ui/components/coral/foundation/container">
                <items jcr:primaryType="nt:unstructured">
                    <autoplay
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                        text="Enable autoplay"
                        name="./autoplay"
                        value="true"
                        uncheckedValue="false"/>
                    <autoplayDelay
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                        fieldLabel="Autoplay delay (ms)"
                        name="./autoplayDelay"
                        min="1000"
                        step="500"
                        emptyText="5000"/>
                    <loop
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                        text="Loop slides"
                        name="./loop"
                        value="true"
                        uncheckedValue="false"/>
                    <showPagination
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                        text="Show pagination dots"
                        name="./showPagination"
                        value="true"
                        uncheckedValue="false"
                        checked="{Boolean}true"/>
                    <showNavigation
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                        text="Show navigation arrows"
                        name="./showNavigation"
                        value="true"
                        uncheckedValue="false"
                        checked="{Boolean}true"/>
                </items>
            </settingsTab>
        </items>
    </content>
</jcr:root>
