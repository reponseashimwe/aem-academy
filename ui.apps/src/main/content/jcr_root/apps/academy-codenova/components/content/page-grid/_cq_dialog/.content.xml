<jcr:root
    xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:jcr="http://www.jcp.org/jcr/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Courses Grid"
    sling:resourceType="cq/gui/components/authoring/dialog"
    sling:resourceSuperType="core/wcm/components/list/v2/list/cq:dialog">

    <content jcr:primaryType="nt:unstructured">
        <items jcr:primaryType="nt:unstructured">

            <tabs jcr:primaryType="nt:unstructured">
                <items jcr:primaryType="nt:unstructured">

                    <!-- Hide ID in List tab -->
                    <listSettings jcr:primaryType="nt:unstructured">
                        <items jcr:primaryType="nt:unstructured">
                            <columns jcr:primaryType="nt:unstructured">
                                <items jcr:primaryType="nt:unstructured">
                                    <column jcr:primaryType="nt:unstructured">
                                        <items jcr:primaryType="nt:unstructured">
                                            <id
                                                jcr:primaryType="nt:unstructured"
                                                sling:hideResource="{Boolean}true"/>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </listSettings>

                    <!-- Hide Show Date in Items tab -->
                    <itemSettings jcr:primaryType="nt:unstructured">
                        <items jcr:primaryType="nt:unstructured">
                            <columns jcr:primaryType="nt:unstructured">
                                <items jcr:primaryType="nt:unstructured">
                                    <column jcr:primaryType="nt:unstructured">
                                        <items jcr:primaryType="nt:unstructured">
                                            <showModificationDate
                                                jcr:primaryType="nt:unstructured"
                                                sling:hideResource="{Boolean}true"/>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </itemSettings>

                    <!-- Custom Grid Settings -->
                    <gridSettings
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Grid Settings"
                        sling:resourceType="granite/ui/components/coral/foundation/container">

                        <items jcr:primaryType="nt:unstructured">

                            <gridColumns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Columns"
                                name="./columns">

                                <items jcr:primaryType="nt:unstructured">
                                    <two jcr:primaryType="nt:unstructured" text="2 columns" value="2"/>
                                    <three jcr:primaryType="nt:unstructured" text="3 columns" value="3"/>
                                    <four jcr:primaryType="nt:unstructured" text="4 columns" value="4"/>
                                </items>

                            </gridColumns>

                            <showImage
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                text="Display page image"
                                name="./showImage"
                                value="true"
                                uncheckedValue="false"/>

                            <showDescription
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                text="Display page description"
                                name="./showDescription"
                                value="true"
                                uncheckedValue="false"/>

                        </items>

                    </gridSettings>

                </items>
            </tabs>

        </items>
    </content>

</jcr:root>