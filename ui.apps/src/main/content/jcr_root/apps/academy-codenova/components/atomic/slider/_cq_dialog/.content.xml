<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Courses Slider"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">

                    <courses
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Courses"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <coursesRoot
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                fieldLabel="Courses Root Path"
                                fieldDescription="Root page whose children are the individual course pages."
                                name="./coursesRoot"
                                rootPath="/content"
                                value="/content/codehills/courses"/>
                            <sortBy
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                fieldLabel="Sort by"
                                fieldDescription="Initial order in which courses are returned."
                                name="./sortBy">
                                <items jcr:primaryType="nt:unstructured">
                                    <none
                                        jcr:primaryType="nt:unstructured"
                                        text="Default (repository order)"
                                        value=""/>
                                    <dateAsc
                                        jcr:primaryType="nt:unstructured"
                                        text="Start Date — Ascending (oldest first)"
                                        value="startDate_asc"/>
                                    <dateDesc
                                        jcr:primaryType="nt:unstructured"
                                        text="Start Date — Descending (newest first)"
                                        value="startDate_desc"/>
                                    <titleAsc
                                        jcr:primaryType="nt:unstructured"
                                        text="Title — A to Z"
                                        value="title_asc"/>
                                    <titleDesc
                                        jcr:primaryType="nt:unstructured"
                                        text="Title — Z to A"
                                        value="title_desc"/>
                                </items>
                            </sortBy>
                            <maxItems
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                fieldLabel="Max Items"
                                fieldDescription="Maximum number of courses to show. Leave empty to show all."
                                name="./maxItems"
                                min="{Long}1"
                                step="{Long}1"/>
                            <filterTags
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/tagfield"
                                fieldLabel="Filter by Tags (OR)"
                                fieldDescription="Only show courses matching at least one of these tags. Leave empty to show all."
                                name="./filterTags"
                                multiple="{Boolean}true"
                                rootPath="/content/cq:tags"/>
                            <showSortControl
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                fieldDescription="Renders a sort dropdown above the slider for visitors."
                                name="./showSortControl"
                                text="Show sort control to visitors"
                                value="{Boolean}true"
                                uncheckedValue="{Boolean}false"/>
                            <showTagFilter
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                fieldDescription="Renders tag-filter chips above the slider for visitors."
                                name="./showTagFilter"
                                text="Show tag filter to visitors"
                                value="{Boolean}true"
                                uncheckedValue="{Boolean}false"/>
                        </items>
                    </courses>

                    <slider
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Slider"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <sliderFields
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/include"
                                path="/apps/academy-codenova/components/common/dialogfields/slidersettings"/>
                        </items>
                    </slider>

                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
