<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
    jcr:primaryType="nt:unstructured"
    sling:resourceType="granite/ui/components/coral/foundation/container">
    <items jcr:primaryType="nt:unstructured">
        <borderRadiusRow
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/container">
            <layout
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/layouts/fixedcolumns"
                method="responsive"/>
            <items jcr:primaryType="nt:unstructured">
                <col1
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/container">
                    <items jcr:primaryType="nt:unstructured">
                        <borderRadius
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                            fieldLabel="Border Radius"
                            name="./borderRadius">
                            <items jcr:primaryType="nt:unstructured">
                                <none jcr:primaryType="nt:unstructured" text="None"    value=""     selected="{Boolean}true"/>
                                <xs   jcr:primaryType="nt:unstructured" text="XSmall"  value="xs"/>
                                <sm   jcr:primaryType="nt:unstructured" text="Small"   value="sm"/>
                                <md   jcr:primaryType="nt:unstructured" text="Medium"  value="md"/>
                                <lg   jcr:primaryType="nt:unstructured" text="Large"   value="lg"/>
                                <xl   jcr:primaryType="nt:unstructured" text="XLarge"  value="xl"/>
                                <full jcr:primaryType="nt:unstructured" text="Full"    value="full"/>
                            </items>
                        </borderRadius>
                    </items>
                </col1>
                <col2
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/container">
                    <items jcr:primaryType="nt:unstructured">
                        <borderRadiusSide
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                            fieldLabel="Apply Border Radius To"
                            name="./borderRadiusSide">
                            <items jcr:primaryType="nt:unstructured">
                                <all    jcr:primaryType="nt:unstructured" text="All corners"  value=""      selected="{Boolean}true"/>
                                <top    jcr:primaryType="nt:unstructured" text="Top"          value="top"/>
                                <bottom jcr:primaryType="nt:unstructured" text="Bottom"       value="bottom"/>
                                <left   jcr:primaryType="nt:unstructured" text="Left"         value="left"/>
                                <right  jcr:primaryType="nt:unstructured" text="Right"        value="right"/>
                                <tl     jcr:primaryType="nt:unstructured" text="Top Left"     value="tl"/>
                                <tr     jcr:primaryType="nt:unstructured" text="Top Right"    value="tr"/>
                                <bl     jcr:primaryType="nt:unstructured" text="Bottom Left"  value="bl"/>
                                <br     jcr:primaryType="nt:unstructured" text="Bottom Right" value="br"/>
                            </items>
                        </borderRadiusSide>
                    </items>
                </col2>
            </items>
        </borderRadiusRow>
    </items>
</jcr:root>
