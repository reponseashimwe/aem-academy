<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    sling:resourceType="granite/ui/components/coral/foundation/container">
    <items jcr:primaryType="nt:unstructured">

        <loop
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
            text="Loop slides"
            fieldDescription="When the last slide is reached, wrap back to the first."
            name="./loop"
            value="true"
            uncheckedValue="false"
            checked="{Boolean}true"/>

        <hideDots
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
            text="Hide pagination dots"
            fieldDescription="Hides the dot indicators below the slides."
            name="./hideDots"
            value="true"
            uncheckedValue="false"/>

        <hideNavigation
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
            text="Hide previous / next buttons"
            fieldDescription="Hides the arrow navigation buttons."
            name="./hideNavigation"
            value="true"
            uncheckedValue="false"/>

    </items>
</jcr:root>
