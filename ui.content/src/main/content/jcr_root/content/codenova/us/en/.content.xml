<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:template="/apps/academy-codenova/templates/homepage"
        jcr:primaryType="cq:PageContent"
        jcr:title="CodeNova"
        pageTitle="CodeNova"
        sling:resourceType="academy-codenova/components/structure/homepage">
        <styledHeader
            jcr:primaryType="nt:unstructured"
            sling:resourceType="academy-codenova/components/content/styled-header"
            jcr:title="Welcome"
            subtitle="Academy"
            customDescription="Building modern AEM experiences"
            position="center"/>
        <heroTitle
            jcr:primaryType="nt:unstructured"
            sling:resourceType="academy-codenova/components/content/title"
            text="CodeNova"
            type="h1"/>
        <heroText
            jcr:primaryType="nt:unstructured"
            sling:resourceType="academy-codenova/components/content/text"
            text="Building modern AEM experiences"/>
        <heroPrimaryButton
            jcr:primaryType="nt:unstructured"
            sling:resourceType="academy-codenova/components/content/button"
            label="Get Started"
            buttonType="filled"
            link="/content/codenova.html"/>
        <heroSecondaryButton
            jcr:primaryType="nt:unstructured"
            sling:resourceType="academy-codenova/components/content/button"
            label="Learn More"
            buttonType="outline"
            link="#"/>
        <par
            jcr:primaryType="nt:unstructured"
            sling:resourceType="wcm/foundation/components/parsys"/>
    </jcr:content>
</jcr:root>
