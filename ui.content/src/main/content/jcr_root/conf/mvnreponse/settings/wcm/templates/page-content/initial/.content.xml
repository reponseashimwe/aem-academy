<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:template="/conf/mvnreponse/settings/wcm/templates/page-content"
        jcr:primaryType="cq:PageContent"
        sling:resourceType="academy-codenova/components/structure/page">
        <codeland-header
            jcr:primaryType="nt:unstructured"
            sling:resourceType="academy-codenova/components/structure/header"
            showSearch="{Boolean}true"
            languageLabel="IT">
            <utilLinks jcr:primaryType="nt:unstructured">
                <item0 jcr:primaryType="nt:unstructured" label="Ateneo" url="/content/mvnreponse/it/ateneo"/>
                <item1 jcr:primaryType="nt:unstructured" label="News" url="/content/mvnreponse/it/news"/>
                <item2 jcr:primaryType="nt:unstructured" label="Ricerca" url="/content/mvnreponse/it/ricerca"/>
                <item3 jcr:primaryType="nt:unstructured" label="FAQ" url="/content/mvnreponse/it/faq"/>
                <item4 jcr:primaryType="nt:unstructured" label="Contatti" url="/content/mvnreponse/it/contatti"/>
            </utilLinks>
        </codeland-header>
        <hero-banner
            jcr:primaryType="nt:unstructured"
            sling:resourceType="academy-codenova/components/atomic/hero-banner"
            showBreadcrumb="{Boolean}false">
            <slides
                jcr:primaryType="nt:unstructured"
                sling:resourceType="academy-codenova/components/atomic/hero-slides"
                currentSlideIndex="0">
                <items jcr:primaryType="nt:unstructured">
                    <item0
                        jcr:primaryType="nt:unstructured"
                        label="Slide 1"
                        hidden="{Boolean}false"
                        slideId="slide01"/>
                </items>
                <slide01
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="academy-codenova/components/atomic/hero-slide"
                    imagePosition="right">
                    <pretitle
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="academy-codenova/components/atomic/title"
                        type="h3"
                        typographyVariant="title-3"/>
                    <title
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="academy-codenova/components/atomic/title"
                        type="h1"
                        typographyVariant="title-2"/>
                    <caption
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="academy-codenova/components/atomic/text"
                        text="&lt;p&gt;Caption text&lt;/p&gt;"
                        textVariant="caption"/>
                    <btn1
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="academy-codenova/components/atomic/button"
                        jcr:title="Iscriviti al corso"
                        linkURL="#"
                        variant="btn--primary"
                        size="btn--md"
                        customIcon="arrow_forward"
                        iconPosition="right"/>
                    <btn2
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="academy-codenova/components/atomic/button"
                        jcr:title="Scarica la brochure"
                        linkURL="#"
                        variant="btn--secondary"
                        size="btn--md"
                        customIcon="download"
                        iconPosition="right"/>
                    <image
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="academy-codenova/components/atomic/image"/>
                </slide01>
            </slides>
        </hero-banner>
        <page-nav
            jcr:primaryType="nt:unstructured"
            sling:resourceType="academy-codenova/components/content/page-nav">
            <utilLinks jcr:primaryType="nt:unstructured">
                <item0 jcr:primaryType="nt:unstructured" label="Panoramica" url="#"/>
                <item1 jcr:primaryType="nt:unstructured" label="Piano di studi" url="#"/>
                <item2 jcr:primaryType="nt:unstructured" label="Stage e professioni" url="#"/>
                <item3 jcr:primaryType="nt:unstructured" label="Esperienze internazionali" url="#"/>
                <item4 jcr:primaryType="nt:unstructured" label="Iscrizioni" url="#"/>
                <item5 jcr:primaryType="nt:unstructured" label="Approfondimenti" url="#"/>
            </utilLinks>
        </page-nav>
        <news
            jcr:primaryType="nt:unstructured"
            sling:resourceType="academy-codenova/components/content/news">
            <title
                jcr:primaryType="nt:unstructured"
                sling:resourceType="academy-codenova/components/atomic/title"
                jcr:title="News"
                type="h2"
                typographyVariant="title-3"
                showDecorator="true"/>
            <description
                jcr:primaryType="nt:unstructured"
                sling:resourceType="academy-codenova/components/atomic/text"
                text="&lt;p&gt;This section presents a collection of academic-style articles focused on key topics related to university life and higher education. &lt;strong&gt;The selected works explore relevant issues such as student well-being&lt;/strong&gt;, technological innovation, sustainability, and international experiences. Together, they provide a broad overview of current trends and challenges shaping modern universities.&lt;/p&gt;"/>
            <slider
                jcr:primaryType="nt:unstructured"
                sling:resourceType="academy-codenova/components/atomic/slider"
                loop="true"/>
        </news>
        <container
            jcr:primaryType="nt:unstructured"
            sling:resourceType="wcm/foundation/components/parsys"/>
        <codeland-footer
            jcr:primaryType="nt:unstructured"
            sling:resourceType="academy-codenova/components/structure/footer"
            copyrightText="© Lorem ipsum dolor sit">
            <sections jcr:primaryType="nt:unstructured">
                <section0 jcr:primaryType="nt:unstructured" title="LINK">
                    <items jcr:primaryType="nt:unstructured">
                        <item0 jcr:primaryType="nt:unstructured" label="Docenti"/>
                        <item1 jcr:primaryType="nt:unstructured" label="Sostieni l'Università"/>
                        <item2 jcr:primaryType="nt:unstructured" label="Vita e pensiero editrice"/>
                        <item3 jcr:primaryType="nt:unstructured" label="Sistema bibliotecario"/>
                        <item4 jcr:primaryType="nt:unstructured" label="Librerie e merchandising"/>
                        <item5 jcr:primaryType="nt:unstructured" label="Giornalisti e media"/>
                        <item6 jcr:primaryType="nt:unstructured" label="Ufficio rapporti con il pubblico"/>
                        <item7 jcr:primaryType="nt:unstructured" label="Contatti"/>
                    </items>
                </section0>
                <section1 jcr:primaryType="nt:unstructured" title="STRUMENTI">
                    <items jcr:primaryType="nt:unstructured">
                        <item0 jcr:primaryType="nt:unstructured" label="Off-campus"/>
                        <item1 jcr:primaryType="nt:unstructured" label="CV Online"/>
                        <item2 jcr:primaryType="nt:unstructured" label="Albo Fornitori"/>
                        <item3 jcr:primaryType="nt:unstructured" label="Bandi e Gare"/>
                        <item4 jcr:primaryType="nt:unstructured" label="Verifica certificati e autocertificazioni"/>
                        <item5 jcr:primaryType="nt:unstructured" label="Intranet"/>
                    </items>
                </section1>
                <section2 jcr:primaryType="nt:unstructured" title="SOCIAL E MEDIA @UNICATT">
                    <items jcr:primaryType="nt:unstructured">
                        <item0 jcr:primaryType="nt:unstructured" label="Facebook"/>
                        <item1 jcr:primaryType="nt:unstructured" label="X"/>
                        <item2 jcr:primaryType="nt:unstructured" label="Linkedin"/>
                        <item3 jcr:primaryType="nt:unstructured" label="Youtube"/>
                        <item4 jcr:primaryType="nt:unstructured" label="Instagram"/>
                        <item5 jcr:primaryType="nt:unstructured" label="Telegram"/>
                        <item6 jcr:primaryType="nt:unstructured" label="Spotify"/>
                        <item7 jcr:primaryType="nt:unstructured" label="Presenza"/>
                    </items>
                </section2>
                <section3 jcr:primaryType="nt:unstructured" title="SECONDO TEMPO">
                    <items jcr:primaryType="nt:unstructured">
                        <item0 jcr:primaryType="nt:unstructured" label="Media center"/>
                        <item1 jcr:primaryType="nt:unstructured" label="Presenza"/>
                        <item2 jcr:primaryType="nt:unstructured" label="Facebook"/>
                        <item3 jcr:primaryType="nt:unstructured" label="X"/>
                        <item4 jcr:primaryType="nt:unstructured" label="Instagram"/>
                    </items>
                </section3>
            </sections>
            <legalLinks jcr:primaryType="nt:unstructured">
                <item0 jcr:primaryType="nt:unstructured" label="Privacy"/>
                <item1 jcr:primaryType="nt:unstructured" label="Cookies"/>
                <item2 jcr:primaryType="nt:unstructured" label="Accessibilità"/>
                <item3 jcr:primaryType="nt:unstructured" label="Impostazione dei Cookies"/>
            </legalLinks>
        </codeland-footer>
    </jcr:content>
</jcr:root>
